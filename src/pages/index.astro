---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Startseite" description="Klarwerk – Digitale Lösungen für Ihr Unternehmen">
  <section class="py-24 px-4">
    <div class="mx-auto max-w-7xl">
      <h1 class="font-headline text-4xl font-bold text-primary md:text-5xl lg:text-6xl">
        Willkommen bei Klarwerk
      </h1>
      <p class="mt-6 max-w-2xl text-lg text-body/70">
        Hier entsteht die Startseite.
      </p>
    </div>
  </section>
</BaseLayout>
