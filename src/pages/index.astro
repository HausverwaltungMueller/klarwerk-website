---
import BaseLayout from '../layouts/BaseLayout.astro';

const leistungen = [
  {
    href: '/leistungen/social-media-content',
    icon: '📱',
    title: 'Social Media & Content',
    text: 'Ihre Kanäle sollen verkaufen, nicht nur existieren. Wir übernehmen Strategie, Inhalte und Veröffentlichung – Sie bleiben sichtbar, ohne Zeit zu investieren.',
  },
  {
    href: '/leistungen/performance-marketing',
    icon: '📊',
    title: 'Performance Marketing',
    text: 'Werbung muss sich rechnen. Wir schalten und optimieren Kampagnen auf Meta und Google konsequent nach Zahlen – transparent, ohne Blackbox.',
  },
  {
    href: '/leistungen/website-erstellung',
    icon: '🖥️',
    title: 'Website-Erstellung',
    text: 'Moderne, schnelle Websites, die auf dem Handy genauso überzeugen wie am PC. Fair kalkuliert ab 1.000 €, in der Regel fertig in ein bis zwei Wochen.',
  },
  {
    href: '/leistungen/ki-automatisierung',
    icon: '⚙️',
    title: 'KI-Automatisierung',
    text: 'Terminerinnerungen, Bewertungsanfragen, Kundenanfragen – alles läuft zuverlässig im Hintergrund. Mehr Anfragen, keine verloren, täglich Zeit gespart.',
  },
];

const schritte = [
  {
    nr: '01',
    titel: 'Erstgespräch',
    text: 'Wir lernen Ihr Unternehmen kennen, verstehen Ihre Ziele und geben eine erste ehrliche Einschätzung – kostenlos und unverbindlich.',
  },
  {
    nr: '02',
    titel: 'Strategie',
    text: 'Auf Basis des Gesprächs entwickeln wir einen klaren Plan: Was machen wir, warum, mit welchem Ziel und wann sehen Sie erste Ergebnisse.',
  },
  {
    nr: '03',
    titel: 'Umsetzung & Reporting',
    text: 'Wir setzen um – und Sie sehen schwarz auf weiß, was läuft. Monatliche Berichte, offene Kommunikation, keine Überraschungen.',
  },
];

const differenzierung = [
  {
    titel: 'Transparent',
    text: 'Kein Marketing-Kauderwelsch, keine versteckten Kosten. Sie wissen jederzeit, wofür Sie bezahlen und was es bringt.',
  },
  {
    titel: 'Datenbasiert',
    text: 'Entscheidungen werden mit Zahlen begründet, nicht mit Bauchgefühl. Jede Maßnahme ist messbar und nachvollziehbar.',
  },
  {
    titel: 'Ohne Knebelvertrag',
    text: 'Monatliche Zusammenarbeit, keine langen Bindungen. Wir verdienen Ihr Vertrauen durch Ergebnisse – nicht durch Vertragsklauseln.',
  },
  {
    titel: 'Automatisierung inklusive',
    text: 'Während andere beim Marketing aufhören, gehen wir weiter. KI-Automatisierung ist kein Aufpreis, sondern Teil unseres Ansatzes.',
  },
];

const faqs = [
  {
    frage: 'Was kostet eine Zusammenarbeit mit Klarwerk?',
    antwort: 'Das hängt von Ihrem Ziel ab. Websites starten ab 1.000 €, Social-Media-Betreuung und Performance Marketing besprechen wir individuell im Erstgespräch. Keine versteckten Kosten.',
  },
  {
    frage: 'Wie lange dauert es, bis ich erste Ergebnisse sehe?',
    antwort: 'Websites sind in der Regel in 1–2 Wochen fertig. Bei Performance-Kampagnen sehen die meisten Kunden nach 2–4 Wochen erste messbare Ergebnisse.',
  },
  {
    frage: 'Bin ich langfristig gebunden?',
    antwort: 'Nein. Wir arbeiten monatlich kündbar. Wir sind überzeugt, dass Sie bleiben wollen, weil die Ergebnisse stimmen – nicht weil ein Vertrag es erzwingt.',
  },
  {
    frage: 'Für wen ist Klarwerk geeignet?',
    antwort: 'Für lokale Unternehmen (Handwerk, Gastronomie, Praxen, Studios) und mittelständische Betriebe bis 250 Mitarbeiter, die online sichtbarer werden und mehr Anfragen generieren wollen.',
  },
  {
    frage: 'Arbeitet ihr auch mit Unternehmen, die noch gar kein Marketing betreiben?',
    antwort: 'Gerade dann. Wir fangen dort an, wo Sie stehen – ohne Vorwürfe, ohne Fachjargon. Das Erstgespräch klärt, was sofort Wirkung zeigt.',
  },
  {
    frage: 'Was ist der Sichtbarkeits-Check?',
    antwort: 'Sie geben uns Ihre Website oder Ihr Social-Media-Profil – wir schauen drauf und liefern 3–5 konkrete Verbesserungspunkte. Kostenlos, unverbindlich, in der Regel innerhalb von 48 Stunden.',
  },
];
---

<BaseLayout
  title="Startseite"
  description="Klarwerk: Marketing-Agentur für lokale & mittelständische Unternehmen. Social Media, Werbeanzeigen & Websites, die messbar Anfragen bringen."
>

  <!-- ═══════════════════════════════════════════════════════
       1. HERO
  ═══════════════════════════════════════════════════════ -->
  <section class="aurora relative overflow-hidden bg-ink clip-diagonal-bottom">
    <!-- Grid overlay -->
    <div class="bg-grid absolute inset-0 z-0 pointer-events-none" aria-hidden="true"></div>

    <div class="relative z-10 mx-auto max-w-5xl px-4 py-28 text-center md:py-36 lg:py-44">
      <!-- Eyebrow -->
      <div class="reveal inline-flex items-center gap-2 rounded-full border border-brand-violet/30 bg-brand-violet/10 px-4 py-1.5 text-xs font-semibold uppercase tracking-widest text-brand-cyan mb-8">
        <span class="h-1.5 w-1.5 rounded-full bg-brand-cyan"></span>
        Digitale Marketing-Agentur
      </div>

      <!-- Headline -->
      <h1 class="reveal font-headline text-4xl font-extrabold leading-[1.1] tracking-tight text-ink-text md:text-6xl lg:text-7xl" style="transition-delay: 0.1s">
        Mehr Sichtbarkeit. Mehr <span class="text-gradient">Anfragen.</span><br class="hidden sm:block" />
        Ohne Marketing-Kauderwelsch.
      </h1>

      <!-- Subline -->
      <p class="reveal mx-auto mt-7 max-w-2xl text-lg leading-relaxed text-ink-text/60 md:text-xl" style="transition-delay: 0.2s">
        Klarwerk bringt lokale und mittelständische Unternehmen online nach vorn – mit Social Media, Werbeanzeigen, Websites und Automatisierung, die messbar Kunden bringen. Transparent, datenbasiert, ohne lange Bindung.
      </p>

      <!-- CTAs -->
      <div class="reveal mt-10 flex flex-col items-center gap-4 sm:flex-row sm:justify-center" style="transition-delay: 0.3s">
        <a
          href="/kontakt"
          class="btn-glow inline-block rounded-xl bg-accent px-8 py-4 text-base font-bold text-white"
        >
          Kostenloses Erstgespräch vereinbaren
        </a>
        <div class="rounded-xl bg-brand-gradient p-px">
          <a
            href="/leistungen"
            class="block rounded-[11px] bg-ink px-8 py-[15px] text-base font-bold text-ink-text transition-colors hover:bg-ink/70"
          >
            Unsere Leistungen ansehen
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       2. VERTRAUENSLEISTE
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-ink px-4 pb-20 pt-16 md:pb-24">
    <div class="mx-auto max-w-5xl">
      <p class="reveal mb-8 text-center text-xs font-semibold uppercase tracking-widest text-ink-text/30">
        Vertraut von Unternehmen aus der Region
      </p>

      <!-- Logo-Platzhalter -->
      <div class="reveal flex flex-wrap items-center justify-center gap-4 md:gap-8" style="transition-delay: 0.1s">
        {[1, 2, 3, 4, 5].map((i, idx) => (
          <div
            class="shimmer flex h-10 w-28 items-center justify-center rounded-lg border border-dashed border-white/10 bg-white/3 text-xs text-ink-text/20"
            style={`transition-delay: ${idx * 0.05}s`}
          >
            Logo {i}
          </div>
        ))}
      </div>

      <!-- Kennzahlen -->
      <div class="reveal mt-14 grid grid-cols-2 gap-6 border-t border-white/5 pt-12 md:grid-cols-4" style="transition-delay: 0.15s">
        {[
          { zahl: '—', label: 'betreute Kunden' },
          { zahl: '—', label: 'Ø ROAS Paid Ads' },
          { zahl: '—', label: 'Websites live' },
          { zahl: '—', label: 'Jahre Erfahrung' },
        ].map(item => (
          <div class="text-center">
            <p class="font-headline text-4xl font-extrabold text-brand-cyan">{item.zahl}</p>
            <p class="mt-1 text-sm text-ink-text/40">{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       3. PROBLEM & LÖSUNG
  ═══════════════════════════════════════════════════════ -->
  <section class="relative bg-[#0D1120] clip-diagonal-both px-4 py-24 md:py-32">
    <div class="bg-grid absolute inset-0 pointer-events-none opacity-60" aria-hidden="true"></div>
    <div class="relative mx-auto max-w-5xl">
      <div class="grid gap-12 md:grid-cols-2 md:gap-20">

        <!-- Problem -->
        <div class="reveal-left">
          <span class="inline-block rounded-full border border-red-500/30 bg-red-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-red-400">
            Das Problem
          </span>
          <h2 class="mt-4 font-headline text-2xl font-bold leading-snug text-ink-text md:text-3xl">
            Sichtbar sein, aber keine Anfragen bekommen?
          </h2>
          <p class="mt-4 leading-relaxed text-ink-text/50">
            Viele Unternehmen posten regelmäßig, haben eine Website – aber die Telefone bleiben still. Marketing ohne Strategie ist verlorene Zeit und verlorenes Geld.
          </p>
        </div>

        <!-- Lösung -->
        <div class="reveal-right" style="transition-delay: 0.1s">
          <span class="inline-block rounded-full border border-brand-cyan/30 bg-brand-cyan/10 px-3 py-1 text-xs font-semibold uppercase tracking-widest text-brand-cyan">
            Die Lösung
          </span>
          <h2 class="mt-4 font-headline text-2xl font-bold leading-snug text-ink-text md:text-3xl">
            Marketing, das messbar Anfragen bringt.
          </h2>
          <p class="mt-4 leading-relaxed text-ink-text/50">
            Klarwerk verbindet Strategie, Kreation und Daten zu einem System, das nicht für Likes optimiert ist – sondern für Kunden. Jede Maßnahme ist nachvollziehbar, jede Investition messbar.
          </p>
        </div>

      </div>

      <div class="mt-14 text-center">
        <a
          href="/leistungen"
          class="inline-block rounded-xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-ink-text transition-colors hover:bg-white/10"
        >
          Leistungen ansehen
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       4. LEISTUNGEN
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-ink px-4 py-24 md:py-32">
    <div class="mx-auto max-w-6xl">
      <div class="reveal text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-cyan">Was wir tun</span>
        <h2 class="mt-3 font-headline text-3xl font-bold text-ink-text md:text-4xl">
          Vier Leistungen. Ein Ziel: mehr Anfragen.
        </h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {leistungen.map((l, i) => (
          <a
            href={l.href}
            class="leistung-card glass-card reveal flex flex-col rounded-2xl p-6"
            style={`transition-delay: ${i * 0.08}s`}
          >
            <span class="card-icon text-3xl">{l.icon}</span>
            <h3 class="mt-4 font-headline text-lg font-bold text-ink-text">{l.title}</h3>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-ink-text/50">{l.text}</p>
            <span class="mt-5 text-sm font-semibold text-brand-violet">
              Mehr erfahren →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       5. SO ARBEITEN WIR
  ═══════════════════════════════════════════════════════ -->
  <section class="relative bg-[#0D1120] clip-diagonal-both px-4 py-24 md:py-32">
    <div class="mx-auto max-w-5xl">
      <div class="reveal text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-cyan">Der Ablauf</span>
        <h2 class="mt-3 font-headline text-3xl font-bold text-ink-text md:text-4xl">
          So arbeiten wir zusammen
        </h2>
      </div>

      <div class="mt-14 grid gap-10 md:grid-cols-3">
        {schritte.map((s, i) => (
          <div class="reveal" style={`transition-delay: ${i * 0.1}s`}>
            <span class="font-headline text-6xl font-extrabold text-gradient opacity-80 leading-none">
              {s.nr}
            </span>
            <h3 class="mt-3 font-headline text-xl font-bold text-ink-text">{s.titel}</h3>
            <p class="mt-3 leading-relaxed text-ink-text/50">{s.text}</p>
          </div>
        ))}
      </div>

      <div class="reveal mt-14 text-center" style="transition-delay: 0.3s">
        <a
          href="/kontakt"
          class="btn-glow inline-block rounded-xl bg-accent px-8 py-4 text-base font-bold text-white"
        >
          Unverbindlich anfragen – Antwort in 24 Stunden
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       6. DIFFERENZIERUNG
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-ink px-4 py-24 md:py-32">
    <div class="mx-auto max-w-5xl">
      <div class="reveal text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-cyan">Warum Klarwerk</span>
        <h2 class="mt-3 font-headline text-3xl font-bold text-ink-text md:text-4xl">
          Anders als klassische Agenturen
        </h2>
      </div>

      <div class="mt-12 grid gap-5 sm:grid-cols-2">
        {differenzierung.map((d, i) => (
          <div
            class="reveal glass-card rounded-2xl p-7"
            style={`transition-delay: ${i * 0.08}s`}
          >
            <div class="mb-3 h-0.5 w-10 rounded-full bg-brand-gradient"></div>
            <h3 class="font-headline text-lg font-bold text-ink-text">{d.titel}</h3>
            <p class="mt-2 text-sm leading-relaxed text-ink-text/50">{d.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       7. REFERENZEN-TEASER
  ═══════════════════════════════════════════════════════ -->
  <section class="relative bg-[#0D1120] clip-diagonal-both px-4 py-24 md:py-32">
    <div class="mx-auto max-w-5xl">
      <div class="reveal text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-cyan">Ergebnisse</span>
        <h2 class="mt-3 font-headline text-3xl font-bold text-ink-text md:text-4xl">
          Was für unsere Kunden entstanden ist
        </h2>
      </div>

      <!-- Referenz-Platzhalter -->
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {[1, 2, 3].map((_, i) => (
          <div
            class="reveal shimmer glass-card rounded-2xl p-6"
            style={`transition-delay: ${i * 0.1}s`}
          >
            <div class="mb-5 flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-white/10"></div>
              <div class="space-y-1.5">
                <div class="h-2.5 w-20 rounded-full bg-white/10"></div>
                <div class="h-2 w-14 rounded-full bg-white/6"></div>
              </div>
            </div>
            <div class="space-y-2 mb-5">
              <div class="h-2 w-full rounded-full bg-white/6"></div>
              <div class="h-2 w-5/6 rounded-full bg-white/6"></div>
              <div class="h-2 w-4/6 rounded-full bg-white/6"></div>
            </div>
            <div class="flex items-center gap-2">
              <span class="font-headline text-3xl font-extrabold text-brand-cyan">—</span>
              <span class="text-xs text-ink-text/30">Platzhalter Ergebnis</span>
            </div>
          </div>
        ))}
      </div>

      <div class="reveal mt-10 text-center" style="transition-delay: 0.3s">
        <a
          href="/referenzen"
          class="inline-block rounded-xl border border-white/10 bg-white/5 px-6 py-3 text-sm font-semibold text-ink-text transition-colors hover:bg-white/10"
        >
          Alle Referenzen ansehen →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       8. ÜBER DEN GRÜNDER
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-ink px-4 py-24 md:py-32">
    <div class="mx-auto max-w-4xl">
      <div class="flex flex-col items-center gap-10 md:flex-row md:items-start md:gap-16">

        <!-- Foto-Platzhalter -->
        <div class="reveal-left flex-shrink-0">
          <div class="relative">
            <div class="absolute inset-0 rounded-2xl bg-brand-gradient opacity-20 blur-xl"></div>
            <div class="relative flex h-44 w-44 items-center justify-center rounded-2xl border border-white/10 bg-white/5 text-xs text-ink-text/30 md:h-52 md:w-52">
              Gründer-Foto
            </div>
          </div>
        </div>

        <!-- Text -->
        <div class="reveal-right" style="transition-delay: 0.1s">
          <span class="text-xs font-semibold uppercase tracking-widest text-brand-cyan">Hinter Klarwerk</span>
          <h2 class="mt-3 font-headline text-2xl font-bold text-ink-text md:text-3xl">
            Kein anonymes Agenturkonstrukt.
          </h2>
          <p class="mt-4 leading-relaxed text-ink-text/55">
            Hinter Klarwerk steht kein anonymes Agenturkonstrukt, sondern ein Unternehmer, der seit über acht Jahren selbst Geschäfte aufbaut – vom ersten eigenen Projekt als Jugendlicher über den Aufbau und Verkauf eines Unternehmens bis hin zur digitalen Vermarktung. Diese Erfahrung prägt unsere Arbeit: Wir denken nicht in Klicks, sondern in Anfragen, Kunden und Umsatz.
          </p>
          <a
            href="/ueber-uns"
            class="mt-6 inline-block text-sm font-semibold text-brand-violet hover:underline"
          >
            Mehr über uns →
          </a>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       9. LEAD-MAGNET
  ═══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden bg-[#0D1120] px-4 py-24 md:py-32">
    <!-- Violet glow -->
    <div class="pointer-events-none absolute left-1/2 top-1/2 h-96 w-96 -translate-x-1/2 -translate-y-1/2 rounded-full bg-brand-violet/10 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-3xl text-center">
      <div class="reveal">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-cyan">Kostenlos & unverbindlich</span>
        <h2 class="mt-3 font-headline text-3xl font-bold text-ink-text md:text-4xl">
          Wie sichtbar sind Sie gerade wirklich?
        </h2>
        <p class="mx-auto mt-4 max-w-xl leading-relaxed text-ink-text/55">
          Wir schauen uns Ihren Online-Auftritt an und liefern 3–5 konkrete Verbesserungspunkte – kostenlos, unverbindlich, in der Regel innerhalb von 48 Stunden.
        </p>
      </div>

      <div class="reveal mt-8 flex flex-col gap-3 sm:flex-row" style="transition-delay: 0.15s">
        <div class="flex-1 rounded-xl bg-brand-gradient p-px">
          <input
            type="url"
            placeholder="Ihre Website oder Social-Media-Profil"
            class="w-full rounded-[11px] bg-[#0D1120] px-4 py-3.5 text-sm text-ink-text placeholder-ink-text/30 outline-none focus:bg-ink"
            disabled
            title="Formular wird verknüpft"
          />
        </div>
        <a
          href="/kontakt"
          class="btn-glow flex-shrink-0 inline-block rounded-xl bg-accent px-5 py-3.5 text-sm font-bold text-white"
        >
          Kostenlosen Sichtbarkeits-Check anfordern
        </a>
      </div>
      <p class="reveal mt-3 text-xs text-ink-text/25" style="transition-delay: 0.2s">
        Formular wird mit dem Kontaktsystem verknüpft. Kein Spam, keine Weitergabe.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       10. FAQ
  ═══════════════════════════════════════════════════════ -->
  <section class="bg-ink px-4 py-24 md:py-32">
    <div class="mx-auto max-w-3xl">
      <div class="reveal text-center">
        <span class="text-xs font-semibold uppercase tracking-widest text-brand-cyan">Häufige Fragen</span>
        <h2 class="mt-3 font-headline text-3xl font-bold text-ink-text md:text-4xl">
          Was Sie wissen möchten
        </h2>
      </div>

      <dl class="mt-12 space-y-1">
        {faqs.map((item, i) => (
          <div
            class="reveal rounded-xl border border-white/5 bg-white/3 px-6 py-5 transition-colors hover:border-brand-violet/20 hover:bg-white/5"
            style={`transition-delay: ${i * 0.06}s`}
          >
            <dt class="font-headline text-base font-bold text-ink-text">{item.frage}</dt>
            <dd class="mt-2 text-sm leading-relaxed text-ink-text/50">{item.antwort}</dd>
          </div>
        ))}
      </dl>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════
       11. ABSCHLUSS-CTA
  ═══════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden px-4 py-24 md:py-32">
    <!-- Full gradient background -->
    <div class="absolute inset-0 bg-brand-gradient opacity-90" aria-hidden="true"></div>
    <div class="bg-grid absolute inset-0 opacity-20" aria-hidden="true"></div>

    <div class="relative mx-auto max-w-3xl text-center">
      <h2 class="reveal font-headline text-3xl font-extrabold text-white md:text-5xl">
        Bereit für mehr Anfragen?
      </h2>
      <p class="reveal mx-auto mt-4 max-w-xl leading-relaxed text-white/75 md:text-lg" style="transition-delay: 0.1s">
        Das Erstgespräch ist kostenlos, dauert 30 Minuten und endet immer mit einer ehrlichen Einschätzung – egal ob wir zusammenarbeiten oder nicht.
      </p>
      <div class="reveal mt-10" style="transition-delay: 0.2s">
        <a
          href="/kontakt"
          class="inline-block rounded-xl bg-white px-9 py-4 text-base font-extrabold text-brand-violet shadow-xl transition-transform hover:-translate-y-1 hover:shadow-2xl"
        >
          Kostenloses Erstgespräch vereinbaren
        </a>
      </div>
      <div class="reveal mt-8 flex flex-col items-center gap-1 text-sm text-white/50 sm:flex-row sm:justify-center sm:gap-6" style="transition-delay: 0.25s">
        <span>info@klarwerk.de</span>
        <span class="hidden sm:inline opacity-40">·</span>
        <span>+49 (0) 000 000 000</span>
        <span class="hidden sm:inline opacity-40">·</span>
        <span>Antwort innerhalb von 24 Stunden werktags</span>
      </div>
    </div>
  </section>

  <!-- ── IntersectionObserver for scroll reveals ─────────── -->
  <script>
    const selectors = ['.reveal', '.reveal-left', '.reveal-right'];
    const allReveal = document.querySelectorAll(selectors.join(','));

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12 }
    );

    allReveal.forEach((el) => observer.observe(el));
  </script>

</BaseLayout>
