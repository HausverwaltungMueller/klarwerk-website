---
const currentPath = Astro.url.pathname;
---

<header id="hdr" style="
  position:fixed;top:0;left:0;right:0;z-index:100;
  padding:1.1rem clamp(1.25rem,5vw,3.5rem);
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid transparent;
  transition:border-color .3s,background .3s,backdrop-filter .3s;
">
  <a href="/" style="font-weight:700;font-size:1.15rem;letter-spacing:-.03em;color:#F2F4F7;text-decoration:none;">
    Klar<span style="color:#00E87A;">werk</span>
  </a>

  <nav id="main-nav" style="display:flex;align-items:center;gap:1.75rem;">
    <a href="/#agenten" class={`nav-link${currentPath === '/' ? '' : ''}`}>KI-Agenten</a>
    <a href="/#fallstudien" class="nav-link">Fallstudien</a>
    <a href="/ueber-uns" class="nav-link">Über uns</a>
    <a href="/kontakt" class="nav-link">Kontakt</a>
    <a href="/#abschluss" class="nav-cta">Kostenloses Erstgespräch</a>
  </nav>

  <button id="mobile-menu-btn" aria-label="Menü" style="display:none;background:none;border:none;color:#F2F4F7;cursor:pointer;padding:.25rem;">
    <svg width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
      <line x1="2" y1="6" x2="20" y2="6"/><line x1="2" y1="11" x2="20" y2="11"/><line x1="2" y1="16" x2="20" y2="16"/>
    </svg>
  </button>
</header>

<style>
  #hdr.scrolled {
    background: rgba(13,15,20,0.88);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    border-color: rgba(255,255,255,0.06);
  }
  .nav-link {
    font-size: .85rem;
    color: #8A8F9E;
    text-decoration: none;
    transition: color .2s;
  }
  .nav-link:hover { color: #F2F4F7; }
  .nav-cta {
    display: inline-flex;
    align-items: center;
    gap: .4rem;
    padding: .55rem 1.1rem;
    background: #00E87A;
    color: #050e08;
    font-size: .8rem;
    font-weight: 700;
    border-radius: 100px;
    text-decoration: none;
    transition: box-shadow .2s, transform .2s;
    box-shadow: 0 0 16px rgba(0,232,122,.2);
  }
  .nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 0 28px rgba(0,232,122,.4);
  }
  @media(max-width:720px) {
    #main-nav { display: none !important; }
    #mobile-menu-btn { display: block !important; }
  }
</style>

<script>
  const hdr = document.getElementById('hdr');
  window.addEventListener('scroll', () => hdr?.classList.toggle('scrolled', scrollY > 50), { passive: true });

  const btn = document.getElementById('mobile-menu-btn');
  const nav = document.getElementById('main-nav');
  btn?.addEventListener('click', () => {
    const open = nav?.style.display === 'flex';
    if (nav) {
      nav.style.display = open ? 'none' : 'flex';
      nav.style.flexDirection = 'column';
      nav.style.position = 'fixed';
      nav.style.top = '60px';
      nav.style.left = '0';
      nav.style.right = '0';
      nav.style.background = 'rgba(13,15,20,0.97)';
      nav.style.padding = '1.5rem clamp(1.25rem,5vw,3.5rem)';
      nav.style.borderBottom = '1px solid rgba(255,255,255,0.06)';
      nav.style.backdropFilter = 'blur(18px)';
      if (open) nav.removeAttribute('style');
    }
  });
</script>
