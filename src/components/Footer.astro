---
const year = new Date().getFullYear();
---

<footer style="
  background:#191D2A;
  border-top:1px solid rgba(255,255,255,0.06);
  padding:3.5rem clamp(1.25rem,5vw,3.5rem) 2rem;
  color:#F2F4F7;
  font-family:'Inter',sans-serif;
">
  <div style="max-width:1160px;margin:0 auto;">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" style="font-weight:700;font-size:1.15rem;letter-spacing:-.03em;color:#F2F4F7;text-decoration:none;display:block;margin-bottom:.9rem;">
          Klar<span style="color:#00E87A;">werk</span>
        </a>
        <p style="font-size:.84rem;color:#8A8F9E;line-height:1.65;max-width:28ch;">
          KI-Agenten für lokale Unternehmen. Weniger Aufwand, mehr Ertrag — in 1–3 Tagen live.
        </p>
      </div>
      <div>
        <h4 class="f-col-label">KI-Agenten</h4>
        <ul style="list-style:none;padding:0;margin:0;">
          <li style="margin-bottom:.55rem;"><a href="/kontakt" class="f-link">A1 Termin-Agent</a></li>
          <li style="margin-bottom:.55rem;"><a href="/kontakt" class="f-link">A2 Bewertungs-Agent</a></li>
          <li style="margin-bottom:.55rem;"><a href="/kontakt" class="f-link">A3 E-Mail-Triage</a></li>
          <li style="margin-bottom:.55rem;"><a href="/kontakt" class="f-link">A4 Lead-Agent</a></li>
        </ul>
      </div>
      <div>
        <h4 class="f-col-label">Unternehmen</h4>
        <ul style="list-style:none;padding:0;margin:0;">
          <li style="margin-bottom:.55rem;"><a href="/ueber-uns" class="f-link">Über uns</a></li>
          <li style="margin-bottom:.55rem;"><a href="/referenzen" class="f-link">Fallstudien</a></li>
          <li style="margin-bottom:.55rem;"><a href="/blog" class="f-link">Blog</a></li>
          <li style="margin-bottom:.55rem;"><a href="/kontakt" class="f-link">Kontakt</a></li>
          <li style="margin-bottom:.55rem;"><a href="/impressum" class="f-link">Impressum</a></li>
          <li style="margin-bottom:.55rem;"><a href="/datenschutz" class="f-link">Datenschutz</a></li>
        </ul>
      </div>
    </div>
    <div style="border-top:1px solid rgba(255,255,255,0.06);padding-top:1.5rem;display:flex;justify-content:space-between;flex-wrap:wrap;gap:.5rem;font-size:.75rem;color:rgba(242,244,247,0.22);">
      <span>© {year} Klarwerk. Alle Rechte vorbehalten.</span>
      <span>info@klarwerk.de</span>
    </div>
  </div>
</footer>

<style>
  .footer-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr 1fr;
    gap: 2.5rem;
    margin-bottom: 2.75rem;
  }
  .f-col-label {
    font-size:.68rem;font-weight:600;letter-spacing:.1em;text-transform:uppercase;
    color:rgba(242,244,247,0.22);margin:0 0 .9rem;
  }
  .f-link {
    font-size:.86rem;color:#8A8F9E;text-decoration:none;transition:color .2s;
  }
  .f-link:hover { color:#F2F4F7; }
  @media(max-width:680px) {
    .footer-grid { grid-template-columns:1fr; }
  }
</style>
